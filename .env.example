# SOC Automation — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control

# =============================================================
# THREAT INTELLIGENCE APIs
# =============================================================

# VirusTotal API v3
# Get from: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB API v2
# Get from: https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Shodan API (optional — for host enrichment)
SHODAN_API_KEY=your_shodan_api_key_here

# AlienVault OTX (optional)
OTX_API_KEY=your_otx_api_key_here

# =============================================================
# SIEM INTEGRATION
# =============================================================

# Splunk
SPLUNK_URL=https://your-splunk-instance:8089
SPLUNK_USERNAME=your_splunk_user
SPLUNK_PASSWORD=your_splunk_password
SPLUNK_TOKEN=your_splunk_hec_token

# Microsoft Sentinel / Log Analytics
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
SENTINEL_WORKSPACE_ID=your_workspace_id

# Elastic/OpenSearch
ELASTIC_URL=https://your-elastic-instance:9200
ELASTIC_API_KEY=your_elastic_api_key
ELASTIC_INDEX=soc-alerts-*

# =============================================================
# EDR INTEGRATION
# =============================================================

# CrowdStrike Falcon
CS_CLIENT_ID=your_crowdstrike_client_id
CS_CLIENT_SECRET=your_crowdstrike_client_secret
CS_BASE_URL=https://api.crowdstrike.com

# Microsoft Defender for Endpoint
MDE_TENANT_ID=your_mde_tenant_id
MDE_CLIENT_ID=your_mde_client_id
MDE_CLIENT_SECRET=your_mde_client_secret

# SentinelOne
S1_BASE_URL=https://your-tenant.sentinelone.net
S1_API_TOKEN=your_sentinelone_api_token

# =============================================================
# CASE MANAGEMENT / TICKETING
# =============================================================

# Jira
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your_jira_email
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SOC

# ServiceNow
SNOW_INSTANCE=your-instance.service-now.com
SNOW_USERNAME=your_snow_username
SNOW_PASSWORD=your_snow_password

# TheHive
THEHIVE_URL=https://your-thehive-instance:9000
THEHIVE_API_KEY=your_thehive_api_key

# =============================================================
# NOTIFICATIONS
# =============================================================

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SOC_CHANNEL=#soc-alerts
SLACK_P1_CHANNEL=#soc-critical

# Microsoft Teams
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook

# PagerDuty
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key
PAGERDUTY_API_KEY=your_pagerduty_api_key

# Email (SMTP)
SMTP_HOST=smtp.your-org.com
SMTP_PORT=587
SMTP_USERNAME=soc-automation@your-org.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=soc-automation@your-org.com
SOC_ALERT_RECIPIENTS=soc-team@your-org.com,ciso@your-org.com

# =============================================================
# FIREWALL / NETWORK
# =============================================================

# Palo Alto NGFW
PA_HOSTNAME=your-firewall.your-org.com
PA_API_KEY=your_palo_alto_api_key

# =============================================================
# APPLICATION SETTINGS
# =============================================================

# General
LOG_LEVEL=INFO
LOG_FORMAT=json
ENVIRONMENT=production

# Rate limiting (seconds between API calls)
API_RATE_LIMIT_DELAY=1

# Triage settings
DEDUP_WINDOW_MINUTES=15
P1_AUTO_ESCALATE=true
FP_SUPPRESSION_ENABLED=true

# Report output directory
REPORT_OUTPUT_DIR=/opt/soc/reports
